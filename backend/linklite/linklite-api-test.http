### ===== EDGE CASE TESTS =====

### 20. Test Very Long URL
POST {{baseUrl}}/api/v1/urls/shorten
Content-Type: application/json

{
  "longUrl": "https://www.example.com/very/long/path/with/many/segments/and/parameters?param1=value1&param2=value2&param3=value3&param4=value4&param5=value5"
}

> {%
client.test("Long URL handling", function() {
    client.assert(response.status === 201, "Expected status 201");
    client.assert(response.body.shortCode !== undefined, "Should generate short code for long URL");
});
%}

###

### 21. Test URL with Special Characters
POST {{baseUrl}}/api/v1/urls/shorten
Content-Type: application/json

{
  "longUrl": "https://www.example.com/path-with-dashes_and_underscores?query=value&another=test"
}

> {%
client.test("Special characters in URL", function() {
    client.assert(response.status === 201, "Expected status 201");
});
%}

### ===== CLEANUP TESTS =====

### 22. Final Analytics Check
GET {{baseUrl}}/api/v1/urls/{{shortCode}}/analytics

> {%
client.test("Final analytics verification", function() {
    client.assert(response.status === 200, "Expected status 200");
    client.assert(response.body.totalClicks >= 3, "Should have accumulated clicks");
    console.log("Final click count: " + response.body.totalClicks);
    console.log("Short code: " + response.body.shortCode);
    console.log("Long URL: " + response.body.longUrl);
});
%}

